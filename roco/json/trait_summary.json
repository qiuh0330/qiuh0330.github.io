{"200074":{"编号":"200074","名称":"偏振","描述":"受到自己携带技能系别的攻击伤害-40%。"},"200075":{"编号":"200075","名称":"目空","描述":"携带的非光系技能，威力+25%。"},"200076":{"编号":"200076","名称":"氧循环","描述":"使用草系技能后，回复10%生命。"},"200077":{"编号":"200077","名称":"勇敢","描述":"携带的能耗大于3的技能，威力+40%。"},"200078":{"编号":"200078","名称":"生物碱","描述":"使用草系技能时，敌方获得2层<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>。"},"200080":{"编号":"200080","名称":"养分重吸收","描述":"回合结束时，回复3能量。"},"200081":{"编号":"200081","名称":"诈死","描述":"自己力竭时，少损失1点魔力。"},"200082":{"编号":"200082","名称":"木桶戏法","描述":"<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>后，更换入场的精灵以木桶状态登场。"},"200083":{"编号":"200083","名称":"腐植循环","描述":"每回复1能量，同时回复5%生命。"},"200084":{"编号":"200084","名称":"营养液泡","描述":"获得<span class=\"game-term\" data-tooltip=\"增加攻击、防御、速度、技能威力、连击数、吸血，或减少技能能耗的效果。\">增益</span>时，额外获得层数+2。"},"200085":{"编号":"200085","名称":"系统发育","描述":"获得能量或生命时，会将等量的能量或生命随机分配给场下的精灵。"},"200087":{"编号":"200087","名称":"生长","描述":"回合结束时，回复12%生命。"},"200088":{"编号":"200088","名称":"挺起胸脯","描述":"携带的能耗为1的技能，威力+50%。"},"200089":{"编号":"200089","名称":"碰瓷","描述":"自己使用恶系技能后，敌方失去2能量。"},"200090":{"编号":"200090","名称":"壮胆","描述":"队伍存在虫系精灵，自己获得双攻+50%。"},"200091":{"编号":"200091","名称":"囤积","描述":"每有1能量，获得双防+10%。"},"200092":{"编号":"200092","名称":"警惕","描述":"回合结束时，若自己能量为0则<span class=\"game-term\" data-tooltip=\"回到背包，玩家手动选择一只其他精灵替换入场。新入场的精灵免疫此效果。\">脱离</span>。"},"200093":{"编号":"200093","名称":"起飞加速","描述":"本场战斗首次使用的技能获得<span class=\"game-term\" data-tooltip=\"精灵主动入场时（非因其他精灵力竭而入场），立即使用第一个可用的技能（需满足能量要求）。一般情况下，此技能的先手顺序由在场双方精灵的速度决定；如果本技能触发了【应对】效果，则改按【应对】的结算顺序处理。\">迅捷</span>。"},"200094":{"编号":"200094","名称":"保守派","描述":"总技能能耗小于4时，自己获得双防+80%。"},"200095":{"编号":"200095","名称":"双向光速","描述":"在场时，双方回合结束时的效果会额外触发1次。"},"200096":{"编号":"200096","名称":"鼓气","描述":"使用能耗为3的技能时，获得攻防+20%。"},"200098":{"编号":"200098","名称":"共鸣","描述":"携带的「虫鸣」技能威力+20。"},"200099":{"编号":"200099","名称":"不移","描述":"携带的无额外效果的攻击技能，威力+30%。"},"200100":{"编号":"200100","名称":"石头大餐","描述":"能量不足时，消耗5%生命，代替1能量。"},"200102":{"编号":"200102","名称":"地脉","描述":"初始能量为0，入场前己方精灵每放1次地系技能，回复3能量。"},"200103":{"编号":"200103","名称":"刺肤","描述":"每受到1次攻击，对攻击自己的精灵造成50威力物理伤害。"},"200104":{"编号":"200104","名称":"石天平","描述":"若使用技能能耗高于敌方，回合结束敌方失去能耗之差的能量。"},"200105":{"编号":"200105","名称":"奔波命","描述":"使用防御技能后，回合结束时<span class=\"game-term\" data-tooltip=\"回到背包，玩家手动选择一只其他精灵替换入场。新入场的精灵免疫此效果。\">脱离</span>。"},"200106":{"编号":"200106","名称":"观星","描述":"敌方每有1层星陨印记，自己的地系技能威力+20%。"},"200107":{"编号":"200107","名称":"浸润","描述":"使用水系技能后，全技能能耗-1。"},"200108":{"编号":"200108","名称":"缩壳","描述":"携带的防御技能能耗-2。"},"200109":{"编号":"200109","名称":"守护者","描述":"己方其他精灵每有1层<span class=\"game-term\" data-tooltip=\"使精灵退回其进化链的上一阶形态，种族值同步降低为上一阶形态，但保留已解锁的特性；若已处于最低形态则无法继续萌化，且需要以萌化为前提才能生效的技能/效果在最低形态下不会触发。萌化可叠加层数；每次获得萌化都会新增1层，叠加至最低形态为止。萌化属于减益系列，但部分技能在获得萌化时会获得额外增益效果。结算顺序默认先结算技能伤害，再使萌化生效。\">萌化</span>，自己入场时全技能能耗-1。"},"200110":{"编号":"200110","名称":"水翼推进","描述":"己方精灵每使用1次水系技能，自己入场时获得全技能能耗-1。"},"200111":{"编号":"200111","名称":"溶解扩散","描述":"每携带1个毒系技能进入战斗，水系技能使敌方获得1层<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>。"},"200112":{"编号":"200112","名称":"倾轧","描述":"携带的技能受能耗变化效果的影响翻倍。"},"200113":{"编号":"200113","名称":"对流","描述":"自己的能耗增加变为能耗降低；能耗降低变为能耗增加。"},"200114":{"编号":"200114","名称":"洄游","描述":"每次进入<span class=\"game-term\" data-tooltip=\"本回合进行蓄力并扣除能量，期间免疫所有离场效果。下回合只可释放已蓄力技能、聚能或下场。如蓄力时释放聚能，蓄力状态依旧存在。\">蓄力</span>状态，获得全技能能耗永久-2。"},"200115":{"编号":"200115","名称":"扩散侵蚀","描述":"使用水系技能后，敌方获得<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>，获得层数等于<span class=\"game-term\" data-tooltip=\"印记效果，回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响。\">中毒印记</span>层数的2倍。"},"200116":{"编号":"200116","名称":"捉迷藏","描述":"使敌方获得<span class=\"game-term\" data-tooltip=\"每层效果冻结目标5%的最大生命值，冻结部分的生命值不可用，当生命低于冻结比例时力竭，换下场依然存在。\">冻结</span>时，也会使其获得全技能能耗+1。"},"200117":{"编号":"200117","名称":"冰钻","描述":"敌方携带技能总能耗每有1点，自己攻击时威力+10%。"},"200118":{"编号":"200118","名称":"结晶水","描述":"初始能量为0，入场前己方精灵每放1次冰系技能，回复3能量。"},"200120":{"编号":"200120","名称":"冻土","描述":"每携带1个冰系技能进入战斗，地系技能威力+10%。"},"200122":{"编号":"200122","名称":"加个雪球","描述":"使敌方获得<span class=\"game-term\" data-tooltip=\"每层效果冻结目标5%的最大生命值，冻结部分的生命值不可用，当生命低于冻结比例时力竭，换下场依然存在。\">冻结</span>时，也会使其获得2层<span class=\"game-term\" data-tooltip=\"每层效果冻结目标5%的最大生命值，冻结部分的生命值不可用，当生命低于冻结比例时力竭，换下场依然存在。\">冻结</span>。"},"200123":{"编号":"200123","名称":"冰封","描述":"在场时，敌方全技能能耗+1。"},"200124":{"编号":"200124","名称":"顺风","描述":"若先于敌方攻击，本次技能威力+50%。"},"200125":{"编号":"200125","名称":"咔咔冲刺","描述":"若先于敌方行动，行动后获得连击数+1。"},"200126":{"编号":"200126","名称":"洁癖","描述":"<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>后，自己的<span class=\"game-term\" data-tooltip=\"增加攻击、防御、速度、技能威力、连击数、吸血，或减少技能能耗的效果。\">增益</span>和<span class=\"game-term\" data-tooltip=\"包含寄生、冻结、灼烧、中毒、萌化的效果，以及降低攻击、防御、速度、技能威力、连击数，或增加技能能耗的效果。\">减益</span>会被更换入场的精灵继承。"},"200128":{"编号":"200128","名称":"乘风连击","描述":"使用翼系技能后，获得连击数+1。"},"200129":{"编号":"200129","名称":"快锤","描述":"携带的能耗小于3的技能，获得<span class=\"game-term\" data-tooltip=\"精灵主动入场时（非因其他精灵力竭而入场），立即使用第一个可用的技能（需满足能量要求）。一般情况下，此技能的先手顺序由在场双方精灵的速度决定；如果本技能触发了【应对】效果，则改按【应对】的结算顺序处理。\">迅捷</span>。"},"200131":{"编号":"200131","名称":"毒腺","描述":"使用能耗小于等于1的技能时，敌方获得4层<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>。"},"200132":{"编号":"200132","名称":"虫群鼓舞","描述":"队伍中每有1只其他的虫系精灵，自己入场时获得攻防速+10%。"},"200133":{"编号":"200133","名称":"振奋虫心","描述":"主动击败敌方后，己方队伍获得5次随机<span class=\"game-term\" data-tooltip=\"使技能[啃咬]和[虫群]获得额外强化，全部精灵共享，强化效果可同时存在并叠加。随机一层奉献的强化效果包括：技能威力+20，攻击附加2层中毒，吸血20%，连击数+1，技能能耗-2。\">奉献</span>。"},"200136":{"编号":"200136","名称":"花精灵","描述":"回合结束时，己方队伍获得1次随机<span class=\"game-term\" data-tooltip=\"使技能[啃咬]和[虫群]获得额外强化，全部精灵共享，强化效果可同时存在并叠加。随机一层奉献的强化效果包括：技能威力+20，攻击附加2层中毒，吸血20%，连击数+1，技能能耗-2。\">奉献</span>。"},"200137":{"编号":"200137","名称":"契约的形状","描述":"根据捕捉所用的咕噜球，入场时获得不同效果。"},"200138":{"编号":"200138","名称":"坚韧铠甲","描述":"每受到1次攻击伤害，己方队伍获得1次随机<span class=\"game-term\" data-tooltip=\"使技能[啃咬]和[虫群]获得额外强化，全部精灵共享，强化效果可同时存在并叠加。随机一层奉献的强化效果包括：技能威力+20，攻击附加2层中毒，吸血20%，连击数+1，技能能耗-2。\">奉献</span>。"},"200139":{"编号":"200139","名称":"渴求","描述":"入场时获得50%<span class=\"game-term\" data-tooltip=\"造成伤害时，按比例回复自身的生命。当作为单次技能效果时，按比例吸血；当作为增益效果时，每次攻击都触发吸血。\">吸血</span>。"},"200140":{"编号":"200140","名称":"悲悯","描述":"己方队伍中每有1只力竭的精灵，自己获得双攻+30%。"},"200141":{"编号":"200141","名称":"付给恶魔的赎价","描述":"击败敌方精灵时，敌方额外损失1点魔力。被敌方精灵击败时，自己额外损失1点魔力。"},"200143":{"编号":"200143","名称":"嫁祸","描述":"自己每失去25%生命，连击数+2。"},"200146":{"编号":"200146","名称":"助燃","描述":"使用火系技能后，获得双攻+20%。"},"200147":{"编号":"200147","名称":"散热","描述":"初始能量为0，入场前己方精灵每放1次火系技能，回复3能量。"},"200148":{"编号":"200148","名称":"斗技","描述":"应对成功后，获得全技能威力永久+30。"},"200149":{"编号":"200149","名称":"专注力","描述":"入场首回合，获得物攻+100%。"},"200150":{"编号":"200150","名称":"灵魂灼伤","描述":"冰系技能使敌方获得4层<span class=\"game-term\" data-tooltip=\"回合结束时，造成2%最大生命的火属性伤害，受属性克制影响，并衰减一半（向上取整）的层数，最少衰减1层，换下场后清除。\">灼烧</span>，火系技能使敌方获得2层<span class=\"game-term\" data-tooltip=\"每层效果冻结目标5%的最大生命值，冻结部分的生命值不可用，当生命低于冻结比例时力竭，换下场依然存在。\">冻结</span>。"},"200152":{"编号":"200152","名称":"仁心","描述":"敌方受到<span class=\"game-term\" data-tooltip=\"回合结束时，造成2%最大生命的火属性伤害，受属性克制影响，并衰减一半（向上取整）的层数，最少衰减1层，换下场后清除。\">灼烧</span>伤害时，自己回复等量生命。"},"200153":{"编号":"200153","名称":"蒸汽膨胀","描述":"己方精灵每使用1次火系技能，自己入场时获得全技能威力+10。"},"200155":{"编号":"200155","名称":"小偷小摸","描述":"入场时偷取敌方场上所有精灵2能量。"},"200156":{"编号":"200156","名称":"下黑手","描述":"敌方精灵<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>后，更换入场的精灵获得5层<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>。"},"200157":{"编号":"200157","名称":"惊吓","描述":"能量等于0的精灵，无法对自己造成伤害。"},"200158":{"编号":"200158","名称":"毒蘑菇","描述":"回合结束时，偷取敌方场上所有精灵1能量。"},"200160":{"编号":"200160","名称":"搜刮","描述":"敌方每使用1次「聚能」技能或更换精灵，自己入场时获得魔攻+20%。"},"200161":{"编号":"200161","名称":"做噩梦","描述":"敌方精灵<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>后，更换入场的精灵失去3能量。"},"200162":{"编号":"200162","名称":"噼啪！","描述":"入场后首次行动，所选技能使用次数+1。"},"200163":{"编号":"200163","名称":"快充","描述":"<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>时回复10能量。"},"200164":{"编号":"200164","名称":"电流刺激","描述":"携带的攻击技能获得<span class=\"game-term\" data-tooltip=\"进入战场首次行动获得额外效果。\">迸发</span>：威力+40。"},"200165":{"编号":"200165","名称":"防过载保护","描述":"每次行动后<span class=\"game-term\" data-tooltip=\"回到背包，玩家手动选择一只其他精灵替换入场。新入场的精灵免疫此效果。\">脱离</span>。"},"200166":{"编号":"200166","名称":"星地善良","描述":"回合结束时，若场上的己方精灵能量等于0，自己立即替换此精灵。"},"200167":{"编号":"200167","名称":"生物电","描述":"携带的电系技能获得<span class=\"game-term\" data-tooltip=\"进入战场首次行动获得额外效果。\">迸发</span>：能耗-2。"},"200169":{"编号":"200169","名称":"蓄电池","描述":"每入场1次，永久获得双攻+30%。"},"200170":{"编号":"200170","名称":"盲拧","描述":"回合开始时，技能顺序打乱，4号位的技能能耗-4。"},"200171":{"编号":"200171","名称":"贪心算法","描述":"1号位技能获得<span class=\"game-term\" data-tooltip=\"回合开始时，带有[传动X]的技能会向下移动X个位置，该效果可叠加。\">传动</span>1，且使用后使敌方获得6层<span class=\"game-term\" data-tooltip=\"回合结束时，造成2%最大生命的火属性伤害，受属性克制影响，并衰减一半（向上取整）的层数，最少衰减1层，换下场后清除。\">灼烧</span>。"},"200172":{"编号":"200172","名称":"定向精炼","描述":"己方精灵每使用1次防御技能，自己入场时机械系和地系技能威力+10%。"},"200173":{"编号":"200173","名称":"暴食","描述":"携带的龙系技能获得<span class=\"game-term\" data-tooltip=\"精灵主动入场时（非因其他精灵力竭而入场），立即使用第一个可用的技能（需满足能量要求）。一般情况下，此技能的先手顺序由在场双方精灵的速度决定；如果本技能触发了【应对】效果，则改按【应对】的结算顺序处理。\">迅捷</span>。"},"200174":{"编号":"200174","名称":"嫉妒","描述":"<span class=\"game-term\" data-tooltip=\"本回合进行蓄力并扣除能量，期间免疫所有离场效果。下回合只可释放已蓄力技能、聚能或下场。如蓄力时释放聚能，蓄力状态依旧存在。\">蓄力</span>状态下，可以使用任一携带技能。"},"200177":{"编号":"200177","名称":"慢热型","描述":"初始能量为0，入场前己方精灵每成功应对1次，回复5能量。"},"200178":{"编号":"200178","名称":"身经百练","描述":"己方精灵每应对1次，自己入场时水系和武系技能威力+20%。"},"200180":{"编号":"200180","名称":"威慑","描述":"<span class=\"game-term\" data-tooltip=\"打断敌人本回合释放的技能。敌方技能不执行，并返还被打断技能的能量。\">打断</span>敌方时，被<span class=\"game-term\" data-tooltip=\"打断敌人本回合释放的技能。敌方技能不执行，并返还被打断技能的能量。\">打断</span>的技能进入2回合冷却。"},"200181":{"编号":"200181","名称":"拨浪鼓","描述":"己方精灵每使用1次状态技能，自己入场时毒系和萌系技能威力+10。"},"200182":{"编号":"200182","名称":"无忧无虑","描述":"可获得的<span class=\"game-term\" data-tooltip=\"使精灵退回其进化链的上一阶形态，种族值同步降低为上一阶形态，但保留已解锁的特性；若已处于最低形态则无法继续萌化，且需要以萌化为前提才能生效的技能/效果在最低形态下不会触发。萌化可叠加层数；每次获得萌化都会新增1层，叠加至最低形态为止。萌化属于减益系列，但部分技能在获得萌化时会获得额外增益效果。结算顺序默认先结算技能伤害，再使萌化生效。\">萌化</span>层数不受限制。"},"200183":{"编号":"200183","名称":"自由飘","描述":"自己每有1层<span class=\"game-term\" data-tooltip=\"使精灵退回其进化链的上一阶形态，种族值同步降低为上一阶形态，但保留已解锁的特性；若已处于最低形态则无法继续萌化，且需要以萌化为前提才能生效的技能/效果在最低形态下不会触发。萌化可叠加层数；每次获得萌化都会新增1层，叠加至最低形态为止。萌化属于减益系列，但部分技能在获得萌化时会获得额外增益效果。结算顺序默认先结算技能伤害，再使萌化生效。\">萌化</span>，获得连击数+2。"},"200185":{"编号":"200185","名称":"毒牙","描述":"使敌方获得<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>时，也会使其获得物攻-40%和速度-40。"},"200186":{"编号":"200186","名称":"复方汤剂","描述":"在场时，双方回合结束时的<span class=\"game-term\" data-tooltip=\"包括中毒和中毒印记效果。\">中毒效果</span>会额外触发1次。"},"200187":{"编号":"200187","名称":"蚀刻","描述":"回合结束时，敌方每2层<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>转化为1层<span class=\"game-term\" data-tooltip=\"印记效果，回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响。\">中毒印记</span>。"},"200189":{"编号":"200189","名称":"吸积盘","描述":"回合结束时，敌方获得2层星陨印记。"},"200191":{"编号":"200191","名称":"最好的伙伴","描述":"造成克制伤害后，获得攻防速+20%，并回复2能量。"},"200192":{"编号":"200192","名称":"绒粉星光","描述":"攻击时，若敌方血脉是非本系的系别血脉，技能威力+100%。"},"200193":{"编号":"200193","名称":"月光审判","描述":"攻击时，若敌方血脉是首领血脉，技能威力+100%。"},"200195":{"编号":"200195","名称":"化茧","描述":"受到致命伤害时，获得1层<span class=\"game-term\" data-tooltip=\"使精灵退回其进化链的上一阶形态，种族值同步降低为上一阶形态，但保留已解锁的特性；若已处于最低形态则无法继续萌化，且需要以萌化为前提才能生效的技能/效果在最低形态下不会触发。萌化可叠加层数；每次获得萌化都会新增1层，叠加至最低形态为止。萌化属于减益系列，但部分技能在获得萌化时会获得额外增益效果。结算顺序默认先结算技能伤害，再使萌化生效。\">萌化</span>，并免疫此次伤害。（最多触发2次）"},"200197":{"编号":"200197","名称":"机械变式","描述":"若回合内自己携带的技能位置发生变化，该技能能耗永久-1。"},"200202":{"编号":"200202","名称":"茶多酚","描述":"<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>后，更换入场的精灵回复20%生命且免疫<span class=\"game-term\" data-tooltip=\"回合结束时，每层吸取6%最大生命值，换下场后清除。\">寄生</span>。"},"200203":{"编号":"200203","名称":"煤渣草","描述":"在场时，所有<span class=\"game-term\" data-tooltip=\"回合结束时，造成2%最大生命的火属性伤害，受属性克制影响，并衰减一半（向上取整）的层数，最少衰减1层，换下场后清除。\">灼烧</span>的衰减变为增长。"},"200204":{"编号":"200204","名称":"侵蚀","描述":"敌方每有1层<span class=\"game-term\" data-tooltip=\"包括中毒和中毒印记效果。\">中毒效果</span>，自己获得连击数+1。"},"200205":{"编号":"200205","名称":"月牙雪糕","描述":"使用攻击技能时，敌方每层冻结视为1层额外星陨印记。"},"200208":{"编号":"200208","名称":"正位宝剑","描述":"仅可以使用1号位技能。"},"200209":{"编号":"200209","名称":"无差别过滤","描述":"在场时，所有精灵连击数固定为2。"},"200210":{"编号":"200210","名称":"守望星","描述":"触发星陨印记时仅消耗一半层数，仍造成满层伤害。"},"200211":{"编号":"200211","名称":"飓风","描述":"对本精灵的技能，若其他翼系精灵携带相同技能，则获得<span class=\"game-term\" data-tooltip=\"精灵主动入场时（非因其他精灵力竭而入场），立即使用第一个可用的技能（需满足能量要求）。一般情况下，此技能的先手顺序由在场双方精灵的速度决定；如果本技能触发了【应对】效果，则改按【应对】的结算顺序处理。\">迅捷</span>。被敌方精灵击败时，自己额外损失1点魔力。"},"200212":{"编号":"200212","名称":"渗透","描述":"己方精灵每使用1次武系或地系技能，自己入场时获得攻防+5%。"},"200213":{"编号":"200213","名称":"得寸进尺","描述":"天气为<span class=\"game-term\" data-tooltip=\"水系环境，天气为雨天时，双方水系技能威力提升50%。\">雨天</span>，或处于其他水系环境中时，获得双攻+100%。"},"200215":{"编号":"200215","名称":"多人宿舍","描述":"自己的能量可以超过能量上限。"},"200216":{"编号":"200216","名称":"珊瑚骨","描述":"敌方精灵<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>时，自己获得全技能能耗-3。"},"200218":{"编号":"200218","名称":"指挥家","描述":"应对成功后，永久获得双攻+30%。"},"200219":{"编号":"200219","名称":"连续负荷","描述":"自己技能的<span class=\"game-term\" data-tooltip=\"进入战场首次行动获得额外效果。\">迸发</span>效果延长1回合。"},"200220":{"编号":"200220","名称":"稀兽花宝","描述":"根据自己的血脉，入场时获得不同效果。"},"200221":{"编号":"200221","名称":"衡量","描述":"入场时，复制敌方的<span class=\"game-term\" data-tooltip=\"增加攻击、防御、速度、技能威力、连击数、吸血，或减少技能能耗的效果。\">增益</span>。在场时，若敌方获得<span class=\"game-term\" data-tooltip=\"增加攻击、防御、速度、技能威力、连击数、吸血，或减少技能能耗的效果。\">增益</span>自己也会获得。"},"200222":{"编号":"200222","名称":"预警","描述":"若敌方技能足够击败自己，回合开始时自己获得速度+50。"},"200223":{"编号":"200223","名称":"铃兰晚钟","描述":"首次入场时，失去自己一半的当前生命。"},"200224":{"编号":"200224","名称":"消波块","描述":"每携带1个水系技能进入战斗，地系技能能耗-1。"},"200225":{"编号":"200225","名称":"吟游之弦","描述":"赋予的<span class=\"game-term\" data-tooltip=\"常驻在全队的效果，不仅仅作用于单个精灵。精灵下场后印记不会消失，新入场的精灵会继承印记效果。每一方同时只能存在1种正面印记和负面印记。\">印记</span>不会替换其他<span class=\"game-term\" data-tooltip=\"常驻在全队的效果，不仅仅作用于单个精灵。精灵下场后印记不会消失，新入场的精灵会继承印记效果。每一方同时只能存在1种正面印记和负面印记。\">印记</span>，而是同时生效。"},"200227":{"编号":"200227","名称":"泛音列","描述":"使用状态技能后，敌方获得「聒噪」技能的效果，持续3回合。"},"200228":{"编号":"200228","名称":"向心力","描述":"1号和2号位技能获得<span class=\"game-term\" data-tooltip=\"回合开始时，带有[传动X]的技能会向下移动X个位置，该效果可叠加。\">传动</span>1和威力+30。"},"200230":{"编号":"200230","名称":"不朽","描述":"力竭4回合后复活。"},"200231":{"编号":"200231","名称":"孤傲","描述":"敌方精灵<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>后，其<span class=\"game-term\" data-tooltip=\"增加攻击、防御、速度、技能威力、连击数、吸血，或减少技能能耗的效果。\">增益</span>和<span class=\"game-term\" data-tooltip=\"包含寄生、冻结、灼烧、中毒、萌化的效果，以及降低攻击、防御、速度、技能威力、连击数，或增加技能能耗的效果。\">减益</span>会被更换入场的精灵继承。"},"200232":{"编号":"200232","名称":"逐魂鸟","描述":"能耗小于等于1的攻击技能，无法对自己造成伤害。"},"200234":{"编号":"200234","名称":"翼轴","描述":"1号位技能获得<span class=\"game-term\" data-tooltip=\"精灵主动入场时（非因其他精灵力竭而入场），立即使用第一个可用的技能（需满足能量要求）。一般情况下，此技能的先手顺序由在场双方精灵的速度决定；如果本技能触发了【应对】效果，则改按【应对】的结算顺序处理。\">迅捷</span>和<span class=\"game-term\" data-tooltip=\"回合开始时，带有[传动X]的技能会向下移动X个位置，该效果可叠加。\">传动</span>1。"},"200235":{"编号":"200235","名称":"虚假宝箱","描述":"自己力竭时，敌方获得攻防+20%。"},"200236":{"编号":"200236","名称":"腾挪","描述":"攻击技能应对1次后，回满状态，变为棋绮后。"},"200237":{"编号":"200237","名称":"保卫","描述":"防御技能应对2次后，回满状态，变为棋绮后。"},"200238":{"编号":"200238","名称":"好象坏象","描述":"状态技能应对1次后，回满状态，变为棋绮后。"},"200240":{"编号":"200240","名称":"耐活王","描述":"敌方受到<span class=\"game-term\" data-tooltip=\"包括中毒和中毒印记效果。\">中毒效果</span>伤害时，自己回复等量生命。"},"200241":{"编号":"200241","名称":"陨落","描述":"在场时，双方回合结束时的效果不会触发。"},"200242":{"编号":"200242","名称":"灰色肖像","描述":"攻击会使敌方已有的<span class=\"game-term\" data-tooltip=\"包含寄生、冻结、灼烧、中毒、萌化的效果，以及降低攻击、防御、速度、技能威力、连击数，或增加技能能耗的效果。\">减益</span>层数+3。"},"200243":{"编号":"200243","名称":"变形活画","描述":"攻击时，敌方每有1层<span class=\"game-term\" data-tooltip=\"增加攻击、防御、速度、技能威力、连击数、吸血，或减少技能能耗的效果。\">增益</span>，本次技能威力+10%。"},"200244":{"编号":"200244","名称":"图书守卫者","描述":"入场时，若自己魔力值为1，自己获得双攻+50%。"},"200245":{"编号":"200245","名称":"构装契约者","描述":"入场时，若敌方魔力值为1，自己获得双防+50%。"},"200247":{"编号":"200247","名称":"圣火骑士","描述":"应对成功后，下次攻击威力翻倍。"},"200248":{"编号":"200248","名称":"思维之盾","描述":"应对成功后，下次行动技能能耗-5。"},"200249":{"编号":"200249","名称":"野性感官","描述":"应对成功后，下次行动<span class=\"game-term\" data-tooltip=\"技能行动的优先级，先手度更高的技能忽略双方精灵速度差异，优先释放。先手值相同时速度更快的一方先出手。\">先手</span>+1。"},"200251":{"编号":"200251","名称":"血型吸引","描述":"敌方每携带1种系别的技能，自己攻击时威力+10。"},"200253":{"编号":"200253","名称":"吉利丁片","描述":"<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>后，更换入场的精灵获得双防+20%且免疫<span class=\"game-term\" data-tooltip=\"每层效果冻结目标5%的最大生命值，冻结部分的生命值不可用，当生命低于冻结比例时力竭，换下场依然存在。\">冻结</span>。"},"200254":{"编号":"200254","名称":"美拉德反应","描述":"<span class=\"game-term\" data-tooltip=\"通过主动更换精灵或触发脱离效果的方式下场（不包括精灵力竭后下场）。\">离场</span>后，更换入场的精灵获得双攻+20%且免疫<span class=\"game-term\" data-tooltip=\"回合结束时，造成2%最大生命的火属性伤害，受属性克制影响，并衰减一半（向上取整）的层数，最少衰减1层，换下场后清除。\">灼烧</span>。"},"200255":{"编号":"200255","名称":"扫拖一体","描述":"回合结束时驱散敌方1层<span class=\"game-term\" data-tooltip=\"常驻在全队的效果，不仅仅作用于单个精灵。精灵下场后印记不会消失，新入场的精灵会继承印记效果。每一方同时只能存在1种正面印记和负面印记。\">印记</span>，且驱散后己方队伍获得1次随机<span class=\"game-term\" data-tooltip=\"使技能[啃咬]和[虫群]获得额外强化，全部精灵共享，强化效果可同时存在并叠加。随机一层奉献的强化效果包括：技能威力+20，攻击附加2层中毒，吸血20%，连击数+1，技能能耗-2。\">奉献</span>。"},"200256":{"编号":"200256","名称":"特殊清洁场景","描述":"回合结束时偷取敌方1层<span class=\"game-term\" data-tooltip=\"常驻在全队的效果，不仅仅作用于单个精灵。精灵下场后印记不会消失，新入场的精灵会继承印记效果。每一方同时只能存在1种正面印记和负面印记。\">印记</span>。"},"200257":{"编号":"200257","名称":"恶魔的晚宴","描述":"主动击败敌方精灵时，自己永久获得双攻+50%。"},"200262":{"编号":"200262","名称":"哨兵","描述":"回合开始时若敌方技能足够击败自己，自己获得速度+50，行动后<span class=\"game-term\" data-tooltip=\"回到背包，玩家手动选择一只其他精灵替换入场。新入场的精灵免疫此效果。\">脱离</span>。"},"200267":{"编号":"200267","名称":"涂鸦","描述":"使用非本系技能时威力+50%。"},"200268":{"编号":"200268","名称":"绝对秩序","描述":"受到非敌方系别的技能攻击时伤害-50%。"},"200269":{"编号":"200269","名称":"张弛有度","描述":"周末时自己获得双攻+40%，其他时间获得双防+40%。"},"200278":{"编号":"200278","名称":"超负荷","描述":"攻击技能获得<span class=\"game-term\" data-tooltip=\"进入战场首次行动获得额外效果。\">迸发</span>：敌方获得全技能能耗+1。"},"200281":{"编号":"200281","名称":"腾挪","描述":"攻击技能应对1次后，回满状态，变为棋绮后。"},"200282":{"编号":"200282","名称":"保卫","描述":"防御技能应对2次后，回满状态，变为棋绮后。"},"200283":{"编号":"200283","名称":"好象坏象","描述":"状态技能应对1次后，回满状态，变为棋绮后。"},"200285":{"编号":"200285","名称":"天通地明","描述":"攻击时，若敌方血脉是污染血脉，技能威力+100%。"},"280001":{"编号":"280001","名称":"浪潮","描述":"使用水系技能后，全技能能耗-2。"},"280002":{"编号":"280002","名称":"深层氧循环","描述":"使用草系技能后，回复15%生命。"},"280003":{"编号":"280003","名称":"爆燃","描述":"使用火系技能后，获得双攻永久+30%。"},"280004":{"编号":"280004","名称":"“国王”的威严","描述":"鸭吉吉国王的种族资质大幅增加，能耗为1的技能威力+50%。"},"280005":{"编号":"280005","名称":"水翼飞升","描述":"己方精灵每使用1次水系技能，自己入场时获得全技能能耗-1，且能耗为0的技能威力+30%。"},"280006":{"编号":"280006","名称":"虫群突袭","描述":"队伍中每有1只其他的虫系精灵，自己入场时获得攻防速+15%。"},"280007":{"编号":"280007","名称":"地脉馈赠","描述":"突破能量上限并立即回复10能量，入场前己方精灵每放1次地系技能，回复3能量。"},"280008":{"编号":"280008","名称":"高浓生物碱","描述":"使用技能时，敌方获得2层<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>。"},"280009":{"编号":"280009","名称":"夺目","描述":"额外获得三个未携带的随机技能，且非光系技能威力+25%。"},"280010":{"编号":"280010","名称":"完全偏振","描述":"抵抗自己携带技能系别的攻击伤害。"},"280011":{"编号":"280011","名称":"坠星","描述":"敌方每有1层星陨印记，自己的技能威力+20%。"},"280012":{"编号":"280012","名称":"抓到你了","描述":"自己入场时敌方获得2层<span class=\"game-term\" data-tooltip=\"每层效果冻结目标5%的最大生命值，冻结部分的生命值不可用，当生命低于冻结比例时力竭，换下场依然存在。\">冻结</span>，使敌方获得<span class=\"game-term\" data-tooltip=\"每层效果冻结目标5%的最大生命值，冻结部分的生命值不可用，当生命低于冻结比例时力竭，换下场依然存在。\">冻结</span>时，也会使其获得全技能能耗+1。"},"280013":{"编号":"280013","名称":"养分内循环","描述":"回合结束时，回复6能量。"},"280014":{"编号":"280014","名称":"全神贯注","描述":"入场时，获得物攻+100%，每次行动后-20%。"},"280015":{"编号":"280015","名称":"大捞一笔","描述":"入场时偷取敌方场上所有精灵3能量。"},"280016":{"编号":"280016","名称":"超级电池","描述":"每入场1次，获得双攻永久+40%。"},"280017":{"编号":"280017","名称":"宝剑王牌","描述":"仅可使用1号和3号位技能。"},"280018":{"编号":"280018","名称":"游弋","描述":"<span class=\"game-term\" data-tooltip=\"本回合进行蓄力并扣除能量，期间免疫所有离场效果。下回合只可释放已蓄力技能、聚能或下场。如蓄力时释放聚能，蓄力状态依旧存在。\">蓄力</span>时可以使用任一携带技能，且获得双防+100%。"},"280019":{"编号":"280019","名称":"御驾亲征","描述":"棋契陛下大幅提升种族资质，力竭时扣除4魔力。"},"280020":{"编号":"280020","名称":"三鼓作气","描述":"使用能耗为3的技能后，获得攻防永久+20%。"},"280021":{"编号":"280021","名称":"先知","描述":"若敌方技能足够击败自己，回合开始时自己获得速度+50，双攻+50%。"},"280022":{"编号":"280022","名称":"溶解腐蚀","描述":"每携带1个毒系技能进入战斗，水系技能使敌方获得2层<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>。"},"280023":{"编号":"280023","名称":"破空","描述":"若先于敌方攻击，本次技能威力+75%。"},"280024":{"编号":"280024","名称":"悼亡","描述":"双方队伍中每有1只力竭的精灵，自己获得双攻+30%。"},"280025":{"编号":"280025","名称":"伙伴的力量","描述":"每学会1个不同系别的技能，获得攻防+5%，且光系技能威力+20%。"},"200286":{"编号":"200286","名称":"狂欢开始","描述":"在场时，背包里会变化出随机精灵，随机精灵只能与本精灵相互更换。本精灵受到的克制伤害+25%。"},"200127":{"编号":"200127","名称":"展翅","描述":"在场时，自己携带的普通系技能变为翼系技能，若后于对手行动，自己受到的伤害+25%。"},"200291":{"编号":"200291","名称":"大雪球","描述":"自己使用2次不同的冰系技能后，对手获得4层<span class=\"game-term\" data-tooltip=\"每层效果冻结目标5%的最大生命值，冻结部分的生命值不可用，当生命低于冻结比例时力竭，换下场依然存在。\">冻结</span>，随后特性重置。"},"200292":{"编号":"200292","名称":"大火球","描述":"自己使用2次不同的火系技能后，下次技能无需<span class=\"game-term\" data-tooltip=\"本回合进行蓄力并扣除能量，期间免疫所有离场效果。下回合只可释放已蓄力技能、聚能或下场。如蓄力时释放聚能，蓄力状态依旧存在。\">蓄力</span>，随后特性重置。"},"200287":{"编号":"200287","名称":"换碟","描述":"自己携带的音波弹/音爆/金属噪音/午夜噪音威力提升，且获得巧变：同系别技能。"},"200288":{"编号":"200288","名称":"拉拉队长","描述":"若自己在<span class=\"game-term\" data-tooltip=\"使精灵退回其进化链的上一阶形态，种族值同步降低为上一阶形态，但保留已解锁的特性；若已处于最低形态则无法继续萌化，且需要以萌化为前提才能生效的技能/效果在最低形态下不会触发。萌化可叠加层数；每次获得萌化都会新增1层，叠加至最低形态为止。萌化属于减益系列，但部分技能在获得萌化时会获得额外增益效果。结算顺序默认先结算技能伤害，再使萌化生效。\">萌化</span>状态下再获得萌化会解除<span class=\"game-term\" data-tooltip=\"使精灵退回其进化链的上一阶形态，种族值同步降低为上一阶形态，但保留已解锁的特性；若已处于最低形态则无法继续萌化，且需要以萌化为前提才能生效的技能/效果在最低形态下不会触发。萌化可叠加层数；每次获得萌化都会新增1层，叠加至最低形态为止。萌化属于减益系列，但部分技能在获得萌化时会获得额外增益效果。结算顺序默认先结算技能伤害，再使萌化生效。\">萌化</span>。"},"200289":{"编号":"200289","名称":"戏耍","描述":"自己回复生命变为敌方扣除等量生命。"},"200273":{"编号":"200273","名称":"焰色反应","描述":"在场时，衰减的<span class=\"game-term\" data-tooltip=\"回合结束时，造成2%最大生命的火属性伤害，受属性克制影响，并衰减一半（向上取整）的层数，最少衰减1层，换下场后清除。\">灼烧</span>变为相同层数的<span class=\"game-term\" data-tooltip=\"回合结束时，造成3%（向下取整）毒属性伤害，受到属性克制影响，换下场后清除。\">中毒</span>。"},"200272":{"编号":"200272","名称":"魔术帽","描述":"在场时，场上双方携带的技能获得巧变：同系别技能。"},"200290":{"编号":"200290","名称":"安可","描述":"使用光系技能后，回合结束时自己<span class=\"game-term\" data-tooltip=\"回到背包，并再次入场，可视为首次进入战场。新入场的精灵免疫此效果。\">返场</span>。"},"200275":{"编号":"200275","名称":"合拍","描述":"若本回合自己与敌方使用的技能在系别/类型/能耗上每有1项相同，回合结束时获得物攻和物防永久+20%。"},"200188":{"编号":"200188","名称":"盲从","描述":"可以携带多个复写/借用/取念技能，非幻系技能能耗-2。"},"200252":{"编号":"200252","名称":"留学生","描述":"自己全技能能耗+2，可以学习全部攻击技能石。"}}